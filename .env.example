# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=talmicahel
POSTGRES_PASSWORD=talmicahel_secret
POSTGRES_DB=talmicahel
DATABASE_URL=postgresql+asyncpg://talmicahel:talmicahel_secret@localhost:5432/talmicahel

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — change this to a random 32+ char string in production
SECRET_KEY=change_me_in_production_32chars_min
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OpenAI (Phase 2 — AI features)
OPENAI_API_KEY=

# App
DEBUG=false
